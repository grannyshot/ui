{
  "name": "@grannyshot/ui",
  "version": "0.1.0",
  "description": "A minimal, theme-aware design system built with Panda CSS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "import": "./dist/styles/index.js",
      "require": "./dist/styles/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js",
      "require": "./dist/context/index.cjs"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "panda codegen && tsup && panda cssgen --outfile dist/styles.css",
    "dev": "panda codegen && tsup --watch"
  },
  "author": "chotaegyu",
  "keywords": [
    "design-system",
    "panda-css",
    "ark-ui",
    "react",
    "ui",
    "components",
    "tokens",
    "theme",
    "dark-mode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grannyshot/ui.git"
  },
  "homepage": "https://grannyshot-ui.vercel.app",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1"
  }
}
