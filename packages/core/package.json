{
  "name": "@grannyshot/ui",
  "version": "0.3.2",
  "description": "A minimal, theme-aware design system built with Tailwind CSS",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "import": "./dist/styles/index.js",
      "require": "./dist/styles/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./styles-no-preflight.css": "./dist/styles-no-preflight.css",
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "CLAUDE.md"
  ],
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsup && npx @tailwindcss/cli -i src/styles.css -o dist/styles.css --minify && node scripts/strip-preflight.cjs",
    "dev": "concurrently \"npx @tailwindcss/cli -i src/styles.css -o dist/styles.css --watch\" \"tsup --watch\""
  },
  "author": "chotaegyu",
  "keywords": [
    "design-system",
    "tailwindcss",
    "ark-ui",
    "react",
    "ui",
    "components",
    "tokens",
    "theme",
    "dark-mode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grannyshot/ui.git"
  },
  "homepage": "https://ui.grannyshot.co.kr",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  }
}
